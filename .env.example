# Nami Environment Configuration
# Copy this file to .env and fill in your values

# ──────────────────────────────────────────────────────────────────────────────
# SERVER-SIDE (Vercel serverless functions)
# These power the /api/* endpoints. Set them in Vercel dashboard or .env.local
# ──────────────────────────────────────────────────────────────────────────────

# EODHD API Token (primary market data provider)
# Get a free account at: https://eodhistoricaldata.com
# Free tier: 20 requests/day, 1 year history
# All World plan ($19.99/mo): 100K requests/day, 30+ years history
EODHD_API_KEY=

# Upstash Redis (server-side cache)
# Create a free database at: https://console.upstash.com
# Free tier: 500K commands/month, 256MB storage
# Or connect via Vercel Marketplace (auto-injects these vars)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ──────────────────────────────────────────────────────────────────────────────
# CLIENT-SIDE (legacy fallback, optional)
# Only needed if the serverless backend is not set up yet
# ──────────────────────────────────────────────────────────────────────────────

# Financial Modeling Prep API Key (legacy fallback)
# Get a free key at: https://financialmodelingprep.com/developer
# Leave empty to use static embedded data only
VITE_FMP_API_KEY=
